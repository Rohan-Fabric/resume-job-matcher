# Copy to .env at the repo root:  cp .env.dev.example .env
# Shared by all services via docker-compose.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# --- Database ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=resume_matcher
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# --- LLM (OpenRouter — OpenAI-compatible API) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Pick any model OpenRouter exposes — this one is free:
OPENROUTER_MODEL=openai/gpt-oss-120b:free
GOOGLE_API_KEY=
OPENROUTER_MODEL_EXTRACT=gemini-2.5-flash
# Tailoring (resume rewrite) can use a separate model:
OPENROUTER_MODEL_TAILOR=openai/gpt-oss-120b:free

# --- Job search sources ---
# Adzuna — dedicated job-listings API (title/location search → structured postings)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_BASE_URL=https://api.adzuna.com/v1/api/jobs
# Jooble — free key, broader coverage alongside Adzuna
JOOBLE_API_KEY=
# Remotive — free, no key, remote-only listings

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Telemetry / Observability ---
# Sentry DSN (optional — leaves disabled if empty)
SENTRY_DSN=

        